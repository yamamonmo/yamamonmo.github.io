---
interface Props {
    name: string;
    count?: number;
    size?: "sm" | "md" | "lg";
}

const { name, count, size = "md" } = Astro.props;

const sizeClasses = {
    sm: "text-xs",
    md: "text-sm",
    lg: "text-base",
};
---

<a href={`/tags/${name.toLowerCase()}`} class={`tag ${sizeClasses[size]}`}>
    #{name}
    {count !== undefined && <span class="opacity-60 ml-1">({count})</span>}
</a>