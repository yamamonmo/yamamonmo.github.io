---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BaseItemCard from "../../components/ui/BaseItemCard.astro";
import { getAllTags, getContentByTag } from "../../utils/tags";
import { getListingItem } from "../../utils/adapters";
import { SITE } from "../../config";

export async function getStaticPaths() {
    const tags = await getAllTags();
    return tags.map((tag) => ({
        params: { tag: tag.name },
        props: { tagName: tag.name },
    }));
}

const { tag } = Astro.params;
const { tagName } = Astro.props;

const content = await getContentByTag(tagName);
---

<BaseLayout title={`#${tagName}`}>
    <header class="page-header">
        <h1 class="page-title">#{tagName}</h1>
        <p class="page-subtitle">Content tagged with "{tagName}"</p>
    </header>

    <section class="item-list">
        {content.map((item) => {
            const listingItem = {
                title: item.data.title || item.id,
                description: item.data.description,
                date: item.data.date,
                authors: item.data.author,
                extraInput: item.data.journal || item.data.event || item.data.institution,
                tags: item.data.tags,
                externalUrl: item.data.external_url,
            };
            const href = `/${item.collection}/${item.id}`;
            return <BaseItemCard {...listingItem} href={href} />;
        })}
    </section>
</BaseLayout>