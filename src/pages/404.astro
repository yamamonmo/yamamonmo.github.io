---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404: Page Not Found">
    <div
        class="flex flex-col items-center justify-center min-h-[50vh] text-center px-4"
    >
        <h1
            class="text-9xl font-black text-accent tracking-tighter sm:text-[12rem] leading-none mb-4"
        >
            404
        </h1>
        <p
            class="text-2xl font-bold text-foreground mb-8 opacity-80"
            aria-label="page not found"
        >
            Page Not Found
        </p>
        <button
            onclick="history.back()"
            class="text-lg font-semibold text-accent hover:underline decoration-2 underline-offset-8 transition-all duration-200 cursor-pointer bg-transparent border-none p-0"
        >
            Go back
        </button>
    </div>
</BaseLayout>
