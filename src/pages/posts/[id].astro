---
import { getCollection } from "astro:content";
import BaseDetail from "../../layouts/BaseDetail.astro";
import ShareButtons from "../../components/ui/ShareButtons.astro";
import { getReadingTime } from "../../utils/readingTime";
import { PAGES, SITE } from "../../config";

if (PAGES.blog.isActive === false) {
    return Astro.redirect("/404");
}

export async function getStaticPaths() {
    if (PAGES.blog.isActive === false) return [];
    const posts = await getCollection("posts");
    const sortedPosts = posts.sort(
        (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
    );

    return sortedPosts.map((post, i) => ({
        params: { id: post.id },
        props: {
            post,
            prevPost: i > 0 ? sortedPosts[i - 1] : null,
            nextPost: i < sortedPosts.length - 1 ? sortedPosts[i + 1] : null,
        },
    }));
}

const { post, prevPost, nextPost } = Astro.props;
const readingTime = `${getReadingTime(post.body || "")} min read`;
const postUrl = new URL(`/posts/${post.id}`, SITE.website).href;
---

<BaseDetail collection="posts" id={post.id} readingTime={readingTime}>
    <nav
        slot="footer"
        class="post-navigation container-narrow flex justify-between mt-24 pt-12 gap-8"
    >
        {
            prevPost && (
                <a
                    href={`/posts/${prevPost.id}`}
                    class="nav-prev flex flex-col group max-w-[45%] no-underline"
                >
                    <span class="nav-label text-[0.8rem] uppercase tracking-wider opacity-75 font-bold mb-2">
                        Previous Post
                    </span>
                    <span class="nav-title text-lg font-semibold text-foreground group-hover:text-accent transition-colors duration-200 leading-snug">
                        {prevPost.data.title}
                    </span>
                </a>
            )
        }
        <div class="nav-spacer flex-1"></div>
        {
            nextPost && (
                <a
                    href={`/posts/${nextPost.id}`}
                    class="nav-next flex flex-col items-end text-right group max-w-[45%] no-underline"
                >
                    <span class="nav-label text-[0.8rem] uppercase tracking-wider opacity-75 font-bold mb-2">
                        Next Post
                    </span>
                    <span class="nav-title text-lg font-semibold text-foreground group-hover:text-accent transition-colors duration-200 leading-snug">
                        {nextPost.data.title}
                    </span>
                </a>
            )
        }
    </nav>
    <div slot="share" class="container-narrow">
        <ShareButtons title={post.data.title} url={postUrl} description={post.data.description} />
    </div>
</BaseDetail>
