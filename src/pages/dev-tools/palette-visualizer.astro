---
import { THEMES, SETTINGS } from "../../config";
import DevToolsLayout from "../../layouts/DevToolsLayout.astro";

const redirect: boolean =
    import.meta.env.PROD && !SETTINGS.addDevToolsInProduction;
if (redirect) {
    return Astro.redirect("/404");
}
---

<DevToolsLayout
    title="Color Palettes"
    description="Minimalist 6-color strip visualizer directly mapping to themes.ts"
>
    <div class="item-list">
        {
            Object.entries(THEMES)
                .filter(([name]) => !name.startsWith("isDark"))
                .map(([name, colors]: [string, any]) => (
                    <div>
                        <h2 class="title-lg mb-4 capitalize">
                            {name.replace("_", " ")}
                        </h2>
                        <div class="flex flex-wrap gap-4">
                            {Object.entries(colors)
                                .filter(([varName]) => varName !== "isDark")
                                .map(
                                ([varName, hexValue]: [string, any]) => (
                                    <div class="flex flex-col gap-2">
                                        <div
                                            class="w-32 h-32 cursor-pointer shrink-0 transition-transform duration-300 hover:-translate-y-1"
                                            style={`background-color: ${hexValue}; border: 1px solid var(--border); border-radius: 0.25rem;`}
                                            title={`${varName}:\n${hexValue}`}
                                        />
                                        <div class="text-left px-1 mt-2">
                                            <div
                                                class="mono"
                                                style="font-weight: 700;"
                                            >
                                                {varName}
                                            </div>
                                            <div
                                                class="mono"
                                                style="font-size: 0.75rem; opacity: 0.7;"
                                            >
                                                {hexValue}
                                            </div>
                                        </div>
                                    </div>
                                ),
                            )}
                        </div>
                    </div>
                ))
        }
    </div>
</DevToolsLayout>
