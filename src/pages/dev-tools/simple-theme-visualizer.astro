---
import { THEMES, SETTINGS } from "../../config";
import DevToolsLayout from "../../layouts/DevToolsLayout.astro";

const redirect: boolean = import.meta.env.PROD && !SETTINGS.addDevToolsInProduction;
if (redirect) {
    return Astro.redirect("/404");
}

const lightThemes = Object.entries(THEMES).filter(([_, t]) => !t.isDark);
const darkThemes = Object.entries(THEMES).filter(([_, t]) => t.isDark);

const sampleHtmlLight = `
<!DOCTYPE html>
<html>
<head>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Inter', system-ui, sans-serif;
            padding: 1.5rem;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
            background: var(--background);
            color: var(--foreground);
        }
        .sidebar {
            width: 280px;
            height: 100vh;
            position: sticky;
            top: 0;
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
            background: var(--background);
        }
        .sidebar-avatar {
            width: 112px;
            height: 112px;
            border-radius: 50%;
            object-fit: cover;
        }
        .sidebar-name {
            font-size: 1.5rem;
            font-weight: 800;
            letter-spacing: -0.02em;
            color: var(--foreground);
        }
        .sidebar-info {
            font-size: 0.85rem;
            color: var(--foreground);
            opacity: 0.7;
        }
        .sidebar-bio {
            font-size: 0.9rem;
            color: var(--foreground);
            opacity: 0.8;
        }
        .main-content {
            flex: 1;
            padding: 1.5rem;
            background: var(--background);
        }
        .card {
            padding: 1rem 0;
        }
        .card-title {
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--foreground);
            text-decoration: none;
            display: block;
            margin-bottom: 0.5rem;
        }
        .card-meta {
            font-size: 0.85rem;
            color: var(--foreground);
            opacity: 0.75;
            display: flex;
            gap: 0.75rem;
        }
        .tag {
            display: inline-flex;
            color: var(--accent);
            font-size: 0.8rem;
            font-weight: 700;
        }
        .btn {
            display: inline-flex;
            padding: 0.5rem 1rem;
            font-weight: 600;
            font-size: 0.9rem;
            background: transparent;
            color: var(--foreground);
            transition: all 0.2s ease;
            text-decoration: none;
        }
        .section-title {
            font-size: 1.2rem;
            font-weight: 700;
            color: var(--foreground);
            margin-bottom: 1rem;
        }
        .color-swatches {
            display: flex;
            gap: 0.75rem;
            flex-wrap: wrap;
        }
        .swatch {
            width: 3rem;
            height: 3rem;
            border-radius: 0.375rem;
        }
        .swatch-label {
            font-size: 0.75rem;
            font-family: monospace;
            margin-top: 0.25rem;
            text-align: center;
            color: var(--foreground);
            opacity: 0.7;
        }
        .swatch-group {
            display: flex;
            flex-direction: column;
            align-items: center;
        }
    </style>
</head>
<body>
    <div style="display: flex; gap: 2rem; width: 100%;">
        <div class="sidebar">
            <img src="https://ui-avatars.com/api/?name=John+Doe&background=random" class="sidebar-avatar" alt="Avatar" />
            <div>
                <h1 class="sidebar-name">John Doe</h1>
                <p class="sidebar-info">University of Science</p>
            </div>
            <p class="sidebar-bio">Short bio text goes here with some information about the researcher.</p>
        </div>
        <div class="main-content">
            <h2 class="section-title">Recent Posts</h2>
            <div class="card">
                <a href="#" class="card-title">Sample Article Title</a>
                <div class="card-meta">
                    <span>Jan 2024</span>
                    <span>Author Name</span>
                </div>
                <div style="margin-top: 0.5rem;">
                    <span class="tag">#tag1</span>
                    <span class="tag">#tag2</span>
                </div>
            </div>
            <div class="card">
                <a href="#" class="card-title">Another Article Title</a>
                <div class="card-meta">
                    <span>Dec 2023</span>
                    <span>Author Name</span>
                </div>
            </div>
            <button class="btn">Load More</button>
        </div>
    </div>
    <div class="color-swatches">
        <div class="swatch-group">
            <div class="swatch" style="background: var(--background)"></div>
            <span class="swatch-label">bg</span>
        </div>
        <div class="swatch-group">
            <div class="swatch" style="background: var(--foreground)"></div>
            <span class="swatch-label">fg</span>
        </div>
        <div class="swatch-group">
            <div class="swatch" style="background: var(--accent)"></div>
            <span class="swatch-label">accent</span>
        </div>
        <div class="swatch-group">
            <div class="swatch" style="background: var(--text-muted)"></div>
            <span class="swatch-label">muted</span>
        </div>
        <div class="swatch-group">
            <div class="swatch" style="background: var(--border)"></div>
            <span class="swatch-label">border</span>
        </div>
        <div class="swatch-group">
            <div class="swatch" style="background: var(--surface)"></div>
            <span class="swatch-label">surface</span>
        </div>
    </div>
</body>
</html>
`;

