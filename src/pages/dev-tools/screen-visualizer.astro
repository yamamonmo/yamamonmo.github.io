---
import { SETTINGS } from "../../config";
import DevToolsLayout from "../../layouts/DevToolsLayout.astro";

const redirect: boolean = import.meta.env.PROD && !SETTINGS.addDevToolsInProduction;
if (redirect) {
    return Astro.redirect("/404");
}

const viewports = [
    { name: "Mobile", width: 375, height: 667, label: "iPhone SE" },
    { name: "Mobile Large", width: 390, height: 844, label: "iPhone 12/13" },
    { name: "Tablet", width: 768, height: 1024, label: "iPad" },
    { name: "Desktop", width: 1280, height: 800, label: "MacBook Air" },
    { name: "Widescreen", width: 1440, height: 900, label: "Desktop" },
];
---

<DevToolsLayout title="Screen Visualizer" description="Responsive testing for common breakpoints.">

            <div class="item-list">
                {
                    viewports.map((vp) => (
                        <div class="flex flex-col gap-4">
                            <div class="flex items-baseline gap-4">
                                <h2 class="title-lg capitalize">
                                    {vp.name}
                                </h2>
                                <span class="mono" style="opacity: 0.5;">
                                    {vp.label} — {vp.width}×{vp.height}px
                                </span>
                            </div>

                            <div class="viewport-frame" style={`width: ${vp.width}px; max-width: 100%;`}>
                                <div class="viewport-header">
                                    <div class="flex gap-1.5">
                                        <div class="w-3 h-3" style="border-radius: 50%; background-color: var(--border);" />
                                        <div class="w-3 h-3" style="border-radius: 50%; background-color: var(--border);" />
                                        <div class="w-3 h-3" style="border-radius: 50%; background-color: var(--border);" />
                                    </div>
                                    <div class="mono" style="background-color: var(--background); padding: 0.25rem 0.75rem; border: 1px solid var(--border); border-radius: 0.25rem; font-size: 0.75rem;">
                                        localhost:4321
                                    </div>
                                    <div class="w-10" />
                                </div>
                                <div class="relative w-full" style={`padding-top: ${(vp.height / vp.width) * 100}%;`}>
                                    <iframe
                                        src="/"
                                        title={`${vp.name} Preview`}
                                        class="absolute top-0 left-0 w-full h-full border-none"
                                    />
                                </div>
                            </div>
                        </div>
                    ))
                }
            </div>
</DevToolsLayout>